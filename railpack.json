{
  "provider": "python",
  "packages": { "python": "3.13" },
  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },
        "pip install -r api/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn api.main:app --host 0.0.0.0 --port $PORT"
  }
}
