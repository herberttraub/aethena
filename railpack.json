{
  "provider": "python",
  "packages": { "python": "3.13" },
  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },
        "python -m venv --copies /app/.venv",
        "/app/.venv/bin/pip install --upgrade pip",
        "/app/.venv/bin/pip install -r api/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "/app/.venv/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port $PORT"
  }
}
